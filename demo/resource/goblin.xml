<?xml version="1.0" encoding="UTF-8"?>
<GoblinConfiguration coreFilename="demo-core.owl" dynamicFilename="demo-dynamic.owl">
    <ModelSection label="Hobbies">
        <Hierarchy
            dynamicAttributeConstraints="VALID_AND_MULTI_IMPLIED_VALUES"
            fixedStructure="false" label="Activity" rootConcept="Activity">
            <AnchoredAttribute anchorConcept="Hobby"
                constraints="VALID_AND_SINGLE_IMPLIED_VALUES"
                label="role performed" rootTargetConcept="Role"
                sourceProperty="involvesActivity" targetProperty="rolePerformed"/>
            <SimpleAttribute
                constraints="VALID_AND_SINGLE_IMPLIED_VALUES"
                label="performed in venue"
                linkingProperty="performedInVenue" rootTargetConcept="VenueByType"/>
        </Hierarchy>
        <Hierarchy dynamicAttributeConstraints="NONE"
            fixedStructure="false" label="Role" rootConcept="Role"/>
    </ModelSection>
    <ModelSection label="Venues">
        <Hierarchy dynamicAttributeConstraints="VALID_VALUES_ONLY"
            fixedStructure="false" label="Venue by type" rootConcept="VenueByType">
            <HierarchicalAttribute label="venue location"
                linksOption="SINGLE_SUPER_CLASSES" rootTargetConcept="VenueByLocation"/>
        </Hierarchy>
        <Hierarchy dynamicAttributeConstraints="NONE"
            fixedStructure="true" label="Venue by location" rootConcept="VenueByLocation"/>
    </ModelSection>
</GoblinConfiguration>
